{
	"name": "celemas/quma",
	"description": "A no-ORM database library for executing raw SQL files",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@celemas.dev"
		}
	],
	"homepage": "https://celemas.dev/quma",
	"keywords": [
		"celemas",
		"database",
		"sql"
	],
	"autoload": {
		"psr-4": {
			"Celemas\\Quma\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Celemas\\Quma\\Tests\\": "tests"
		}
	},
	"require": {
		"php": "^8.5",
		"ext-json": "*",
		"ext-pdo": "*",
		"ext-readline": "*",
		"ext-tokenizer": "*",
		"celemas/cli": "^0.2"
	},
	"require-dev": {
		"celemas/dev": "^4.1"
	},
	"scripts": {
		"test:base": "./vendor/bin/phpunit --testdox --no-coverage --colors=always",
		"test:sqlite": "QUMA_TEST_DRIVERS=sqlite composer test:base",
		"test:mysql": "QUMA_TEST_DRIVERS=mysql composer test:base",
		"test:pgsql": "QUMA_TEST_DRIVERS=pgsql composer test:base",
		"test:all": "QUMA_TEST_DRIVERS=sqlite,mysql,pgsql composer test:base",
		"test": "composer test:base",
		"coverage:test": "php -d xdebug.mode=coverage ./vendor/bin/phpunit --testdox --path-coverage --colors=always",
		"coverage:analyze": "./vendor/bin/coverlyzer .coverage/coverage.php",
		"coverage": [
			"composer coverage:test",
			"composer coverage:analyze"
		],
		"coverage:all": "QUMA_TEST_DRIVERS=sqlite,mysql,pgsql composer coverage",
		"types": "./vendor/bin/psalm --no-cache",
		"lint": [
			"./vendor/bin/mago fmt --check",
			"./vendor/bin/mago lint"
		],
		"docs:format": "npx prettier@3.6.2 --write --config ./docs/.prettierrc README.md CHANGELOG.md LICENSE.md docs/",
		"docs:lint": "npx markdownlint-cli2@0.22.1 --config ./vendor/celemas/dev/config/markdownlint.jsonc README.md CHANGELOG.md LICENSE.md docs/",
		"ci": [
			"composer lint",
			"composer coverage:all",
			"composer types",
			"composer docs:lint"
		]
	}
}
